	(text "3.3V = (26V * R2)/(R1 + R2)\n0.127 = R2 / (R1 + R2)\n-> 0.1 = R2 / (R1 + R2)\nR2 = 10k\nR1 = 90k\n(R2 + R1) = 100k\n\nV = IR\n26V / 100k = 0.26mA\n\nDisarmed w/continuity = (3.3-0.7) * 0.1 = 0.26V\nArmed w/continuity = 26 * 0.1 = 2.6V\n"
		(exclude_from_sim no)
